GOOGLE_CLIENT_ID=ID_DO_SEU_CLIENT_AQUI.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=SECRET_DO_SEU_CLIENT_AQUI

GOOGLE_REDIRECT_URI=http://localhost:8000/google/callback
GOOGLE_CALENDAR_ID=primary

# Senha do administrador padrão (campusananindeua@uepa.br).
# Obrigatória: se vazia, o admin não é criado no startup.
ADMIN_SEED_PASSWORD=

# Senha inicial atribuída a professores importados via planilha.
# O administrador deve comunicá-la aos professores para o primeiro acesso.
# Se vazia, uma senha aleatória é gerada (professor não conseguirá entrar sem reset).
PROFESSOR_DEFAULT_PASSWORD=